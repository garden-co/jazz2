{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "rootDir": ".",
    "sourceMap": false,
    "inlineSources": false,
    "paths": {
      "jazz-tools": ["./src/index.ts"],
      "jazz-tools/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "tests/ts-dsl/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.svelte.test.ts",
    "src/svelte/test-helpers.svelte.ts"
  ]
}
